# Public browser-exposed values
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional public ad configuration
# Leave blank for local development and portfolio review builds.
NEXT_PUBLIC_GOOGLE_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_REWARDED_AD_UNIT=

# Server-only values
TMDB_API_READ_ACCESS_TOKEN=your-tmdb-read-access-token
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
ADMIN_API_SECRET=your-admin-api-secret

# Server-only (never exposed to browser)
TMDB_API_READ_ACCESS_TOKEN=your-tmdb-read-access-token
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
ADMIN_API_SECRET=your-admin-api-secret
